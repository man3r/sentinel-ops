# ─────────────────────────────────────────────────────────────────────────────
# SentinelOps Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:localdev@localhost:5432/sentinelops

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default                    # Override for local dev (e.g. sentinelops-dev)

# Bedrock Model IDs
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_ENDPOINT=https://your-collection.us-east-1.aoss.amazonaws.com
OPENSEARCH_INDEX=sentinelops-incidents

# ── Slack ─────────────────────────────────────────────────────────────────────
# Get these from https://api.slack.com/apps > your app > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_INCIDENT_CHANNEL=#incidents

# ── Perception Engine ─────────────────────────────────────────────────────────
# URL of the Llama 3B inference service (separate process)
PERCEPTION_ENGINE_URL=http://localhost:8001

# ── Llama Model (Perception Engine only) ──────────────────────────────────────
LLAMA_MODEL_PATH=/models/Llama-3.2-3B-Instruct

# ── Agent Behaviour ───────────────────────────────────────────────────────────
MIN_CONFIDENCE_THRESHOLD=0.75          # Below this, no action is taken
REASONING_TIMEOUT_SECONDS=180          # Max time allowed for Bedrock RCA call
